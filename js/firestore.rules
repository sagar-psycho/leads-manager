// ============================================================
// FIRESTORE COMPOSITE INDEX REQUIRED
// The member-scoped leads query uses:
//   .where("assignedTo", "==", uid).orderBy("slNo", "desc")
// This requires a composite index. Create it in the Firebase console:
//   Collection: leads
//   Fields:     assignedTo  (Ascending)
//               slNo        (Descending)
// Or deploy via firestore.indexes.json.
// ============================================================
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function myUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myRole() {
      return isSignedIn() && myUserDoc().data.active == true
        ? myUserDoc().data.role
        : null;
    }

    function isSuperAdmin() { return isSignedIn() && myRole() == 'superadmin'; }
    function isAdmin()      { return isSignedIn() && myRole() == 'admin'; }
    function isMember()     { return isSignedIn() && myRole() == 'member'; }
    function isStaff()      { return isSuperAdmin() || isAdmin(); }

    // Returns true when the write touches ONLY the aiSettings field
    // and nothing else — so users can't use this path to elevate their role.
    function isAISettingsUpdateOnly() {
      let incoming = request.resource.data.diff(resource.data).affectedKeys();
      return incoming.hasOnly(['aiSettings']);
    }

    // ── USERS ──────────────────────────────────────────────
    match /users/{userId} {

      // Every active authenticated user can read the team list
      // (needed for dropdowns and assignment names).
      allow read: if isSignedIn() && myUserDoc().data.active == true;

      // Super Admin: full create / update / delete
      allow create: if isSuperAdmin();
      allow delete: if isSuperAdmin();

      // Super Admin: unrestricted update.
      // Any authenticated user: may update ONLY their own aiSettings field.
      allow update: if isSuperAdmin()
        || (isSignedIn()
            && request.auth.uid == userId
            && isAISettingsUpdateOnly());
    }

    // ── LEADS ───────────────────────────────────────────────
    match /leads/{leadId} {
      allow read: if isStaff()
        || (isMember() && resource.data.assignedTo == request.auth.uid);

      allow create: if isStaff();
      allow delete: if isSuperAdmin();

      allow update: if isSuperAdmin()
        || (isMember()
            && resource.data.assignedTo == request.auth.uid
            && request.resource.data.assignedTo  == resource.data.assignedTo
            && request.resource.data.fullName     == resource.data.fullName
            && request.resource.data.phoneNumber  == resource.data.phoneNumber
            && request.resource.data.email        == resource.data.email
            && request.resource.data.companyName  == resource.data.companyName
            && request.resource.data.serviceNeeded == resource.data.serviceNeeded
            && request.resource.data.slNo         == resource.data.slNo
            && request.resource.data.campaignId   == resource.data.campaignId
            && request.resource.data.campaignName == resource.data.campaignName
            && request.resource.data.campaignData == resource.data.campaignData);
    }

    // ── META (counters, round-robin) ─────────────────────────
    match /meta/{docId} {
      allow read:  if isStaff();
      allow write: if isStaff();
    }

    // ── AUDIT TRAIL for deleted leads ────────────────────────
    match /deletedLeadsAudit/{docId} {
      allow read:          if isSuperAdmin();
      allow create:        if isSuperAdmin();
      allow update, delete: if false;
    }

    // ── CRM SETTINGS ─────────────────────────────────────────
    // All settings live in ONE document: crmSettings/general
    // Read : every active authenticated user (settings are applied to their session).
    // Write: Super Admin only — enforced both here AND in the JS layer.
    match /crmSettings/{docId} {
      allow read:           if isSignedIn() && myUserDoc().data.active == true;
      allow create, update: if isSuperAdmin();
      allow delete:         if isSuperAdmin();
    }

    // ── ASSIGNMENT QUEUE ──────────────────────────────────────
    // Holds leads waiting for assignment (outside office hours / holiday / no members).
    // Staff (Admin/SA) create entries when creating a lead.
    // System (SA + Admin clients) delete entries after dispatching.
    match /assignmentQueue/{docId} {
      allow read:           if isSignedIn() && myUserDoc().data.active == true;
      allow create:         if isStaff();
      allow delete:         if isStaff();
      allow update:         if isStaff();
    }

    // ── AUDIT LOG ─────────────────────────────────────────────
    // Append-only log of every automatic assignment action.
    // All staff can read; system (staff clients) create entries.
    match /auditLog/{docId} {
      allow read:           if isStaff();
      allow create:         if isSignedIn() && myUserDoc().data.active == true;
      allow update, delete: if false;
    }

    // ── EMPLOYEE LEAVE ────────────────────────────────────────
    // Super Admin + Admin: full CRUD.
    // Member: read own leaves; create own leave requests.
    match /leaves/{docId} {
      allow read: if isStaff()
        || (isMember() && resource.data.memberId == request.auth.uid);
      allow create: if isSignedIn() && myUserDoc().data.active == true;
      allow update: if isStaff();
      allow delete: if isStaff();
    }

    // ── CALL AUDITS ───────────────────────────────────────────
    // Sales Member: create audits, read own audits
    // Admin/SA: read all, update (approve/reject/request re-call)
    match /callAudits/{auditId} {
      allow read: if isStaff()
        || (isMember() && resource.data.salesMemberId == request.auth.uid);
      allow create: if isMember() 
        && request.resource.data.salesMemberId == request.auth.uid
        && request.resource.data.status == "Pending";
      allow update: if isStaff()
        && (request.resource.data.status in ["Approved", "Rejected", "Re-Call Requested"]);
    }

    // ── CALL AUDIT LOG ────────────────────────────────────────
    // Append-only log of audit actions (approve/reject/re-call)
    match /callAuditLog/{docId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if false;
    }

    // ── NOTIFICATIONS ─────────────────────────────────────────
    // Users can read their own notifications, create notifications
    match /notifications/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isStaff(); // Admins create notifications
    }

    // ── CAMPAIGNS (Campaign Form Builder) ─────────────────────
    // Read: every active authenticated user (Admins need the list for
    // the Add Lead "Campaign Type" dropdown; Members see campaignName
    // already denormalized on their leads, but read access is harmless).
    // Write (create/edit/delete/activate/deactivate): Super Admin only.
    match /campaigns/{campaignId} {
      allow read:                    if isSignedIn() && myUserDoc().data.active == true;
      allow create, update, delete:  if isSuperAdmin();
    }

    // ── CAMPAIGN FIELDS (per-campaign custom lead fields) ─────
    // Read: every active authenticated user (Admins need the field
    // definitions to render the Add Lead form for the chosen campaign).
    // Write: Super Admin only — enforced both here AND in the JS layer.
    match /campaignFields/{fieldId} {
      allow read:                    if isSignedIn() && myUserDoc().data.active == true;
      allow create, update, delete:  if isSuperAdmin();
    }
  }
}
